{
  "manifest_version": 3,
  "name": "PornRips Zip Downloader (1080p)",
  "version": "1.0.0",
  "description": "Scrapes 1080p videos from PornRips date pages and downloads them in a structured ZIP file.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "downloads",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://pornrips.to/*",
    "https://pixhost.to/*",
    "https://*.pixhost.to/*"
  ],
  "action": {
    "default_title": "Open PornRips Zip Downloader",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
